# EditorConfig — consistent coding style across editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# MediaWiki extension standard: tabs for PHP, JSON, XML
[*.{php,json,xml,neon}]
indent_style = tab
indent_size = 4

# YAML uses spaces
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be significant (line breaks)
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Composer lockfile — auto-generated, leave as-is
[composer.lock]
indent_style = space
indent_size = 4
