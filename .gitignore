# Composer dependencies
/vendor/
# Note: composer.lock is intentionally NOT ignored. Committing the lockfile
# ensures fully reproducible CI builds (see KI-092 / P2-093 in CHANGELOG.md).
# Action required before first release: run `composer install` locally on
# PHP 8.1+ and commit the generated composer.lock.

# Composer phar (local download, not committed)
/composer.phar
/composer-setup.php

# IDE / editor files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.vs/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# PHPUnit cache
/.phpunit.cache/

# PHP logs / temp
*.log
*.cache
