<?xml version="1.0"?>
<ruleset name="MediaWiki ODBC Extension">
	<description>PHP_CodeSniffer ruleset for the MediaWiki ODBC Extension. Run: composer phpcs</description>

	<!-- Apply MediaWiki coding standards -->
	<rule ref="MediaWiki"/>

	<!-- Source files to check -->
	<file>includes/</file>
	<file>ODBCMagic.php</file>

	<!-- Exclude generated and third-party paths -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<!-- Allow longer lines for SQL and log messages -->
	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="160"/>
			<property name="absoluteLineLimit" value="200"/>
		</properties>
	</rule>
</ruleset>
